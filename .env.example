# Application URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=https://www.swopme.app
NEXT_PUBLIC_CHECKOUT_BASE_URL=https://app.swopme.co

# Hyperliquid Perpetuals
# Set to "true" to point all perps hooks at the Hyperliquid testnet
# (wss://api.hyperliquid-testnet.xyz, Arbitrum Sepolia bridge).
# Leave unset or "false" for mainnet.
NEXT_PUBLIC_HYPERLIQUID_TESTNET=false


# Privy Configuration
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_DELEGATED_SIGNER_ID=
NEXT_PUBLIC_PRIVY_DELEGATED_POLICY_IDS=

## Privy Server-side Configuration (for sponsored transactions)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Solana wallet ID used as Jupiter fee payer for no-SOL swaps.
PRIVY_SIGNER_WALLET_ID=
# Optional cache of that wallet's Solana address; if omitted, the server fetches
# it from Privy using PRIVY_SIGNER_WALLET_ID.
PRIVY_SIGNER_WALLET_ADDRESS=

# Blockchain RPC URLs
## EVM Networks
NEXT_PUBLIC_ALCHEMY_ETH_URL=
NEXT_PUBLIC_ALCHEMY_POLYGON_URL=
NEXT_PUBLIC_ALCHEMY_BASE_URL=
NEXT_PUBLIC_ALCHEMY_ARBITRUM_URL=

## Solana Networks
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_SOCKET_URL=

# Alchemy EVM API key
NEXT_PUBLIC_ALCHEMY_ETH_API_KEY=
NEXT_PUBLIC_ALCHEMY_POLYGON_API_KEY=
NEXT_PUBLIC_ALCHEMY_BASE_API_KEY=
NEXT_PUBLIC_ALCHEMY_ARBITRUM_API_KEY=

# Blockchain Explorer API Keys
NEXT_PUBLIC_ETHERSCAN_API_KEY_TOKEN=
NEXT_PUBLIC_POLYGONSCAN_API_KEY_TOKEN=
NEXT_PUBLIC_BASESCAN_API_KEY_TOKEN=
NEXT_PUBLIC_SOLSCAN_API_KEY=

# Wallet Configuration
NEXT_PUBLIC_FEE_PAYER_ADDRESS=

# Google API Configuration
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Environment Configuration
NODE_ENV=
NEXT_PUBLIC_IGNORE_BUILD_ERROR=

# Sandbox
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

NEXT_PUBLIC_MORALIS_API_KEY=

NEXT_PUBLIC_HELIUS_API_KEY=

# LiFi Configuration
# Required for reliable EVM swaps. Without LIFI_API_KEY, quotes use the keyless
# rate-limited public host and intermittently time out. See CLAUDE.md "Swap Quote Reliability".
LIFI_API_URL=
LIFI_API_KEY=

# Dflow APIs

NEXT_PUBLIC_DFLOW_API_URL=
NEXT_PUBLIC_DFLOW_API_KEY=

# Jupiter Configuration
# Required for reliable Solana swaps. With JUPITER_API_KEY, quotes use the pro host
# api.jup.ag; without it the route falls back to the shared rate-limited lite-api.jup.ag
# and intermittently times out ("quote is taking too long"). Get a key at portal.jup.ag.
NEXT_PUBLIC_JUPITER_API_URL=
JUPITER_API_KEY=

NEXT_PUBLIC_POLYMARKET_API_URL=http://localhost:5055

# Polymarket CLOB V2 — builder code for order attribution (bytes32 hex from polymarket.com/settings?tab=builder)
NEXT_PUBLIC_POLY_BUILDER_CODE=
